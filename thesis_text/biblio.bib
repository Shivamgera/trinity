@ARTICLE{Prior2008-hx,
  title    = "Repositioning Documents in Social Research",
  author   = "Prior, Lindsay",
  abstract = "In matters of social research sociologists and other social
              scientists have tended to view documents primarily as sources of
              evidence and as receptacles of inert content.The key strategies
              for data exploration have consequently been associated with
              various styles of content or thematic analysis. Even when
              discourse analysis has been recommended, there has been a marked
              tendency to deal with records, files, and the like, primarily as
              containers --- things to be read, understood, and categorized. In
              this article, however, the author seeks to demonstrate that by
              focussing on the functioning of documents instead of content,
              sociology can embrace a much wider range of approaches to both
              data collection and analysis. Indeed, the adoption of such a
              programme encourages researchers to see documents as active
              agents in the world, and to view documentation as a key component
              of dynamic networks rather than as a set of static and immutable
              `things'.",
  journal  = "Sociology",
  volume   =  42,
  number   =  5,
  pages    = "821--836",
  month    =  "1~" # oct,
  year     =  2008,
  language = "en"
}


