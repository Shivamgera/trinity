@ARTICLE{Avenier2010-cp,
  title    = "Shaping a Constructivist View of Organizational Design Science",
  author   = "Avenier, Marie-Jos{\'e}",
  abstract = "The so-called rigor---relevance gap appears unbridgeable in the
              classical view of organization science, which is based on the
              physical sciences’ model. Constructivist scholars have also
              pointed out a certain inadequacy of this model of science for
              organization research, but they have not offered an explicit,
              alternative model of science. Responding to this lack, this paper
              brings together the two separate paradigmatic perspectives of
              constructivist epistemologies and of organizational design
              science, and shows how they could jointly constitute the
              ingredients of a constructivism-founded scientific paradigm for
              organization research. Further, the paper highlights that, in
              this constructivist view of organizational design science,
