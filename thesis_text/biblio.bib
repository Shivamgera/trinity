@INPROCEEDINGS{Dix2007-ef,
  title     = "Designing for Appropriation",
  booktitle = "Proceedings of the 21st British {HCI} Group Annual Conference on
               People and Computers: {HCI...But} Not As We Know It - Volume 2",
  author    = "Dix, Alan",
  abstract  = "Ethnographies often show that users appropriate and adapt
               technology in ways never envisaged by the designers, or even
               deliberately subverting the designers' intentions. As design can
               never be complete, such appropriation is regarded as an
               important and positive phenomenon. However designing for
