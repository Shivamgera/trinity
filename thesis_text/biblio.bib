	file = {Full Text PDF:/Users/shivamgera/Zotero/storage/ZZ5TRZIQ/Wawer and Chudziak - 2025 - Integrating Traditional Technical Analysis with AI A Multi-Agent LLM-Based Approach to Stock Market.pdf:application/pdf;Snapshot:/Users/shivamgera/Zotero/storage/DCPVG8LL/2506.html:text/html},
