	year = {2025},
	keywords = {Deep reinforcement learning (DRL), energy and carbon trading, integrated energy system (IES), large language model (LLM), price mechanisms, trading strategies},
	pages = {8186--8197},
}

@inproceedings{silva_deep_2025,
