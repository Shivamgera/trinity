@INPROCEEDINGS{Holmstrom2014-yv,
  title      = "Logic for Accumulation of Design Science Research Theory",
  booktitle  = "2014 47th Hawaii International Conference on System Sciences
                ({HICSS})",
  author     = "Holmstr{\"o}m, J and Tunanen, T and Kauremaa, J",
  abstract   = "The paper introduces a structured logic for iterative and
                incremental accumulation of a design theory during a research
                project and across research programs. The logic is proposed to
                help researchers understand the links between parallel search
                spaces related to a particular design and linking to
                theoretical knowledge bases produced by previous search
                processes. The proposition rests on the notion that
                representing the structure and logic of design science research
                (DSR) theory using CIMO enables the elements of the knowledge
                base to be more easily evaluated, combined, and transferred
