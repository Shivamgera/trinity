@article{mantshimuli_sentiment-aware_2025,
	title = {Sentiment-{Aware} {Portfolio} {Optimization}: {CVaR}-{Based} {Diversification} {With} {Deep} {Reinforcement} {Learning}},
	volume = {13},
	issn = {2169-3536},
	shorttitle = {Sentiment-{Aware} {Portfolio} {Optimization}},
	doi = {10.1109/ACCESS.2025.3624652},
	abstract = {This paper presents an innovative portfolio optimization framework that synergistically integrates CVaR-based diversification with Deep Reinforcement Learning (DRL) and sentiment analysis from a Large Language Model (LLM). Traditional optimization methods, such as Mean-Variance Optimization (MVO) and Most Diversified Portfolio (MDP) strategies, often fall short in capturing tail risks and adapting to dynamic market conditions. In contrast, our approach employs the Deep Deterministic Policy Gradient (DDPG) DRL algorithm to dynamically adjust asset allocations taking transaction costs into account while explicitly managing downside risk via Conditional Value-at-Risk (CVaR). To further enhance the decision-making process, sentiment scores derived from the FinBERT LLM are incorporated into the state space, enabling the model to capture qualitative market signals and improve risk-adjusted performance. Empirical evaluations reveal that our portfolio, the DRL Sentiment-Aware CVaR Ratio Portfolio, outperforms benchmark strategies, including Equally Weighted, Minimum CVaR, and traditional MDP portfolios, by achieving higher annualized returns, improved Sharpe and Omega ratios, and elevated Jensen’s alpha. These promising results underscore the potential of combining robust risk management measures for portfolio diversification with advanced machine learning techniques and sentiment analysis to navigate the complexities of contemporary financial markets. Future research directions include extending the framework to multi-asset classes, integrating additional alternative data sources, and exploring alternative DRL algorithms to further enhance performance. © 2013 IEEE.},
	language = {English},
	journal = {IEEE Access},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	author = {Mantshimuli, Lamukanyani A.},
	year = {2025},
	keywords = {conditional value-at-risk (CVaR), CVaR diversification ratio, deep deterministic policy gradient (DDPG), deep reinforcement learning (DRL), FinBERT, most diversified portfolio (MDP), Portfolio optimization, sentiment analysis},
	pages = {182690--182704},
	file = {Full Text PDF:/Users/shivamgera/Zotero/storage/HRYLYALW/Mantshimuli - 2025 - Sentiment-Aware Portfolio Optimization CVaR-Based Diversification With Deep Reinforcement Learning.pdf:application/pdf},
}

@misc{ding_large_2024,
	title = {Large {Language} {Model} {Agent} in {Financial} {Trading}: {A} {Survey}},
	shorttitle = {Large {Language} {Model} {Agent} in {Financial} {Trading}},
	url = {http://arxiv.org/abs/2408.06361},
	doi = {10.48550/arXiv.2408.06361},
	abstract = {Trading is a highly competitive task that requires a combination of strategy, knowledge, and psychological fortitude. With the recent success of large language models(LLMs), it is appealing to apply the emerging intelligence of LLM agents in this competitive arena and understanding if they can outperform professional traders. In this survey, we provide a comprehensive review of the current research on using LLMs as agents in financial trading. We summarize the common architecture used in the agent, the data inputs, and the performance of LLM trading agents in backtesting as well as the challenges presented in these research. This survey aims to provide insights into the current state of LLM-based financial trading agents and outline future research directions in this field.},
