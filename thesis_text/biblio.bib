@article{idowu_model_2025,
	title = {Model {Robustness} to {Adversarial} {Data} in {Financial} {Time} {Series}},
	abstract = {Financial time series models are critical for tasks such as risk assessment, portfolio optimization, and algorithmic trading. However, their reliability is increasingly threatened by adversarial data-subtle, malicious perturbations designed to mislead predictive models. This paper explores the robustness of various financial forecasting models, including deep learning architectures and traditional statistical methods, under adversarial attack scenarios. We investigate the susceptibility of these models to adversarial inputs crafted using gradient-based and optimization-based methods, and assess performance degradation across different market conditions. To mitigate vulnerabilities, we examine defense mechanisms such as adversarial training, input preprocessing, and robust optimization. Our findings highlight a significant disparity in robustness across model types, with deep neural networks being particularly sensitive to small perturbations. We propose a framework for evaluating model resilience in realworld financial environments and underscore the necessity of integrating robustness considerations into the design and deployment of financial forecasting systems. The study provides key insights for practitioners aiming to safeguard financial models against adversarial manipulation and ensure more trustworthy predictive performance.},
	author = {Idowu, Marvel},
	month = may,
	year = {2025},
	file = {Full Text PDF:/Users/shivamgera/Zotero/storage/9UEZHJRF/Idowu - 2025 - Model Robustness to Adversarial Data in Financial Time Series.pdf:application/pdf},
}

@article{chen_diversity_2024,
	title = {Diversity supporting robustness: {Enhancing} adversarial robustness via differentiated ensemble predictions},
	volume = {142},
	issn = {0167-4048},
	shorttitle = {Diversity supporting robustness},
	url = {https://www.sciencedirect.com/science/article/pii/S0167404824001627},
	doi = {10.1016/j.cose.2024.103861},
	abstract = {Deep learning models remain susceptible to adversarial attacks, prompting a primary focus on individual defense strategies. Previous studies have shown that increasing diversity among ensemble models can enhance their adversarial robustness. However, existing diversity metrics often lack a direct association with robustness, potentially limiting ensemble methods’ effectiveness in countering adversarial attacks. This paper presents a new diversity training method, termed Enhancing Adversarial Robustness through Diversity that Supports Robustness (EADSR), which is strongly linked to increased adversarial robustness. We developed a safety space hypothesis and a simultaneous training method based on the models’ responsiveness to non-natural perturbations which amplifies ensemble model diversity. By categorizing the ensemble models’ prediction behaviors into four classes, four regularization methods are applied for diversity training throughout the training process. We conducted comparative analysis with existing diversity methods to find a remarkable 30\%–100\% improvement on multiple benchmark datasets. The EADSR method incurs manageable training costs and is applicable to complex datasets such as ImageNet, demonstrating its effectiveness and practicality as a defense approach.},
	urldate = {2026-02-11},
	journal = {Computers \& Security},
	author = {Chen, Xi and Huang, Wei and Peng, Ziwen and Guo, Wei and Zhang, Fan},
	month = jul,
	year = {2024},
	keywords = {Adversarial defence, Deep learning, Ensemble learning, Image classification, Models diversity},
	pages = {103861},
}

