@BOOK{Giddens1986-gl,
  title     = "The Constitution of Society: Outline of the Theory of
               Structuration",
  author    = "Giddens, Anthony",
  abstract  = "Anthony Giddens has been in the forefront of developments in
               social theory for the past decade. In The Constitution of
